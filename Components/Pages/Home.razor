<section id="about" class="py-5">
    <div class="container">
        <h2 class="fw-bold mb-4">About Me</h2>
       <p class="lead text-dark fw-bold">
            I'm a Full Stack .NET Developer with experience building
            secure web applications, service platforms, media systems,
            and note management solutions.
            My focus is on creating reliable applications using
            ASP.NET Core, Blazor, Entity Framework Core, SQL Server,
            Bootstrap and modern web technologies. I have a passion for clean code,
            responsive design, and delivering great user experiences. And am also focused on building secure, scalable web applications for businesses and startups.

My primary stack includes ASP.NET Core, Blazor, Entity Framework Core, SignalR, SQL Server and PostgreSQL.

I enjoy turning ideas into products that people actually use.
        </p>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="py-5 shadow-lg">
    <div class="container ">
        <h2 class="fw-bold mb-5 text-center">What I Can Build</h2>
        <div class="row g-4">
            @foreach (var service in Services)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card h-100 border-0 shadow-sm text-center p-3">
                        <div class="card-body">
                            <i class="bi bi-check-circle-fill text-primary fs-1 mb-3"></i>
                            <h6 class="fw-bold mb-0">@service</h6>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="fw-small mb-5">Skills</h2>
        <div class="row g-3">
            @foreach(var skill in Skills)
            {
                <div class="col-md-3">
                    <div class="card glass h-100">
                        <div class="card-body text-center">
                            <h5>@skill</h5>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="projects" class="py-5 shadow">
    <div class="container">
        <h2 class="section-title">Featured Projects</h2>
        <div class="row g-4">
            @foreach (var project in Projects)
            {
                <div class="col-lg-4">
                    <div class="card glass h-100 border-0 shadow text-dark fw-bold">
                        
                        @if (project.ImageUrls != null && project.ImageUrls.Any())
                        {
                            <div id="carousel-@project.Name.Replace(" ", "")" class="carousel slide" data-bs-ride="carousel">
                                <div class="carousel-inner">
                                    @for (int i = 0; i < project.ImageUrls.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <a href="@project.ImageUrls[i]">
                                                <img src="@project.ImageUrls[i]"
                                                     class="project-image d-block w-100"
                                                     alt="@project.Name" />
                                            </a>
                                        </div>
                                    }
                                </div>
                                <button class="carousel-control-prev" type="button" data-bs-target="#carousel-@project.Name.Replace(" ", "")" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carousel-@project.Name.Replace(" ", "")" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            </div>
                        }

                        <div class="card-body">
                            <h4 class="fw-bold">@project.Name</h4>
                            <p>@project.Description</p>
                            <div class="mb-3">
                                @foreach (var tech in project.Tech)
                                {
                                    <span class="badge bg-primary me-1">@tech</span>
                                }
                            </div>
                            @*<a href="@project.Url" target="_blank" class="btn btn-outline-dark btn-lg me-2" data-bs-toggle="tooltip" data-bs-placement="top" title="View Live Demo">Live Demo</a>
                            <a href="@project.GithubUrl" target="_blank" class="btn btn-outline-dark btn-lg" data-bs-toggle="tooltip" data-bs-placement="top" title="View on GitHub"><i class="bi bi-github"></i> GitHub</a>*@
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section id="contact" class="py-5 bg-dark text-light">
    <div class="glass p-5">

        <h2 class="fw-bold mb-4">Let's Build Something Together</h2>
        <p>Available for freelance work, collaborations, and full-time opportunities.</p>
        <div class="mt-4">
            <a href="mailto:mkolowo222@gmail.com" class="btn btn-outline-info btn-sm shadow me-3 " data-bs-toggle="tooltip" 
            data-bs-placement="top" title="Send me an email">
                <i class="bi bi-envelope"></i> Email Me
            </a>
            <a href="https://github.com/mikesbult" target="_blank" class="btn btn-outline-light btn-sm shadow me-3" data-bs-toggle="tooltip"
             data-bs-placement="top" title="View on GitHub">
                <i class="bi bi-github"></i> GitHub
            </a>
            <a href="https://www.linkedin.com/in/mikes-bult-615b59409/" 
            target="_blank" class="btn btn-outline-info btn-sm shadow" 
            data-bs-toggle="tooltip"
             data-bs-placement="top" title="Connect on LinkedIn">
                <i class="bi bi-linkedin"></i> LinkedIn
            </a>
        </div>
    </div>
</section>

<footer class="py-4 text-center text-dark fw-bold">

    <p>
        © @DateTime.Now.Year Mike'sBult.
